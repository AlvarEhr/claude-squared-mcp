# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
build/

# Versioned .mcpb builds — regenerable from source via scripts/build_and_install_extension.py
# The latest stable copy at the project root (claude-squared.mcpb) IS tracked
# so the built plugin is downloadable directly from the repo.
dist/

# Extension staging dir — most contents are auto-generated by the build script:
#   - server/lib/ : ~150 MB of vendored Python deps (pydantic, fastmcp, etc.) installed by the bundler
#   - src/claude_squared/ : a mirror of ../src/claude_squared/ synced fresh on every build
# We track the small hand-maintained files in extension/ (manifest.json, icon.png,
# pyproject.toml, server/main.py, uv.lock) and let the build regenerate the rest.
extension/server/lib/
extension/src/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Local-only env / secrets (none currently, but defensive)
.env
.env.local
*.local

# Internal engineering reference — kept locally for working with agents,
# not published to the repo (per the lean-repo cleanup pass).
HANDOFF.md

# Lock files / temp state from running the MCP locally — these live under
# ~/.claude/pairs/ in user home, not in the repo, but extra defense:
*.lock.owner
